            "body": {
              "mode": "raw",
              "raw": "{\n  \"startDate\": \"2026-06-10\",\n  \"endDate\": \"2026-06-12\",\n  \"leaveType\": \"CASUAL\",\n  \"reason\": \"Family vacation\"\n}"
            }
          }
        },
