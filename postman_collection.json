{
  "info": {
    "_postman_id": "elms-collection-v1",
    "name": "ELMS API Collection",
    "description": "Employee Leave Management System — all REST endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
